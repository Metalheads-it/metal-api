{
    "name": "metal-api",
    "version": "1.0.0",
    "description": "Metal API is a REST API written in JS for retrieving data from the website Encyclopedia Metallum (https://www.metal-archives.com/)",
    "main": "src/server.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "test": "npx tsx --test-reporter spec --test $(find ./tests -name '*.ts')",
        "test:coverage": "c8 npx tsx --test tests/",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/giacomocamerano/metal-api.git"
    },
    "author": "Giacomo Camerano",
    "license": "GPL-3.0",
    "bugs": {
        "url": "https://github.com/giacomocamerano/metal-api/issues"
    },
    "homepage": "https://github.com/giacomocamerano/metal-api#readme",
    "dependencies": {
        "@types/node": "^20.12.12",
        "fastify": "^4.27.0",
        "node-html-parser": "^6.1.13",
        "typescript": "^5.4.5"
    },
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^9.3.0",
        "c8": "^9.1.0",
        "eslint": "^9.3.0",
        "eslint-config-prettier": "^9.1.0",
        "esmock": "^2.6.5",
        "globals": "^15.3.0",
        "husky": "^8.0.0",
        "lint-staged": "^15.2.5",
        "pino-pretty": "^11.1.0",
        "prettier": "^3.2.5"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged && npm run lint",
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
            "post-merge": "npm i"
        }
    },
    "lint-staged": {
        "./src/**/*.{js,json,md}, ./tests/**/*.{js,json,md}": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}
