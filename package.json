{
    "name": "metal-api",
    "version": "1.0.0",
    "description": "Metal API is a REST API written in JS for retrieving data from the website Encyclopedia Metallum (https://www.metal-archives.com/)",
    "main": "src/server.js",
    "scripts": {
        "start:dev": "nodemon -r dotenv/config -w ./src ./src/index.ts --dev | pino-pretty -clSt",
        "dist": "node dist/server.js",
        "build": "tsc -p tsconfig.json",
        "test": "npx tsx --test-reporter spec --test $(find ./tests -name '*.ts')",
        "test:coverage": "c8 npx tsx --test tests/",
        "lint": "esw .",
        "lint:watch": "npm run lint -- --watch",
        "lint:fix": "eslint . --fix",
        "prepare": "husky"
    },
    "ts-node": {
        "swc": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/giacomocamerano/metal-api.git"
    },
    "author": "Giacomo Camerano",
    "license": "GPL-3.0",
    "bugs": {
        "url": "https://github.com/giacomocamerano/metal-api/issues"
    },
    "homepage": "https://github.com/giacomocamerano/metal-api#readme",
    "dependencies": {
        "@fastify/swagger": "^9.1.0",
        "@fastify/swagger-ui": "^5.0.1",
        "@fastify/type-provider-typebox": "^5.0.0",
        "@sinclair/typebox": "^0.33.16",
        "dotenv": "^16.4.5",
        "fastify": "^5.0.0",
        "fastify-plugin": "^5.0.1",
        "node-html-parser": "^6.1.13",
        "typescript": "^5.4.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.3.0",
        "@types/eslint__js": "^8.42.3",
        "@types/node": "^22.7.5",
        "c8": "^9.1.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-unicorn": "^53.0.0",
        "eslint-watch": "^8.0.0",
        "esmock": "^2.6.5",
        "globals": "^15.3.0",
        "husky": "^8.0.0",
        "lint-staged": "^15.2.5",
        "pino-pretty": "^11.1.0",
        "prettier": "^3.2.5",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript-eslint": "^7.11.0"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged && npm run lint",
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
            "post-merge": "npm i"
        }
    },
    "lint-staged": {
        "./src/**/*.{js,json,md,ts}, ./tests/**/*.{js,json,md,ts}": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}
